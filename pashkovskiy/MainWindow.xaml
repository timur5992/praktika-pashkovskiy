<Window x:Class="TeplomasterPlus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тепломастер Плюс - Учёт заявок" Height="550" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="📋 Система учёта заявок" FontSize="22" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <!-- Панель фильтрации -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Right">
            <TextBlock Text="Фильтр по статусу:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox x:Name="CmbFilter" Width="120" Margin="5" SelectionChanged="CmbFilter_SelectionChanged">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="Новая"/>
                <ComboBoxItem Content="В работе"/>
                <ComboBoxItem Content="Выполнена"/>
            </ComboBox>
        </StackPanel>

        <!-- Таблица заявок -->
        <DataGrid x:Name="RequestsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                  AlternatingRowBackground="LightGray" RowHeaderWidth="0" Margin="0,5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Client}" Width="150"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Оборудование" Binding="{Binding Equipment}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="200"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTemplateColumn Header="Действие" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="❌ Удалить" Click="BtnDelete_Click" Tag="{Binding Id}" 
                                    Background="Red" Foreground="White" BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статистика -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10" HorizontalAlignment="Center">
            <TextBlock x:Name="TxtTotal" Text="Всего: 0" Margin="15,0" FontWeight="Bold"/>
            <TextBlock x:Name="TxtNewCount" Text="Новых: 0" Margin="15,0" Foreground="Blue"/>
            <TextBlock x:Name="TxtWorkCount" Text="В работе: 0" Margin="15,0" Foreground="Orange"/>
            <TextBlock x:Name="TxtDoneCount" Text="Выполнено: 0" Margin="15,0" Foreground="Green"/>
        </StackPanel>

        <!-- Форма добавления -->
        <Border Grid.Row="4" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
            <StackPanel>
                <TextBlock Text="➕ Добавление новой заявки" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ФИО клиента:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtClient" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

                    <TextBlock Text="Телефон:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtPhone" Grid.Row="0" Grid.Column="3" Margin="5" Height="30"/>

                    <TextBlock Text="Оборудование:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtEquipment" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

                    <TextBlock Text="Статус:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbStatus" Grid.Row="1" Grid.Column="3" Margin="5" Height="30" SelectedIndex="0">
                        <ComboBoxItem Content="Новая"/>
                        <ComboBoxItem Content="В работе"/>
                        <ComboBoxItem Content="Выполнена"/>
                    </ComboBox>

                    <TextBlock Text="Описание:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Top"/>
                    <TextBox x:Name="TxtDescription" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" 
                             Margin="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <Button x:Name="BtnAdd" Grid.Row="3" Grid.Column="3" Content="✅ Добавить заявку" 
                            Width="150" Height="35" Margin="5" Click="BtnAdd_Click" 
                            Background="Green" Foreground="White" FontWeight="Bold"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>