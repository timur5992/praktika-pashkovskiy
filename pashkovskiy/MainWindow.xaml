<Window x:Class="TeplomasterPlus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тепломастер Плюс" 
        Height="600" Width="900" 
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="🔥 ООО Тепломастер Плюс" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма добавления заявки -->
        <Border Grid.Row="1" Background="#ECF0F1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="➕ Новая заявка" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="Клиент:" FontWeight="Bold"/>
                        <TextBox x:Name="TxtClient" Height="30" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="Телефон:" FontWeight="Bold"/>
                        <TextBox x:Name="TxtPhone" Height="30" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="Оборудование:" FontWeight="Bold"/>
                        <TextBox x:Name="TxtEquipment" Height="30" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="Статус:" FontWeight="Bold"/>
                        <ComboBox x:Name="CmbStatus" Height="30" Margin="0,5,0,0" SelectedIndex="0">
                            <ComboBoxItem Content="Новая"/>
                            <ComboBoxItem Content="В работе"/>
                            <ComboBoxItem Content="Выполнена"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Text="Описание:" FontWeight="Bold"/>
                        <TextBox x:Name="TxtDescription" Height="50" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>

                <Button x:Name="BtnAdd" Content="Добавить заявку" Background="#27AE60" Foreground="White" 
                        Height="35" Margin="0,10,0,0" Click="BtnAdd_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Список заявок -->
        <Border Grid.Row="2" Background="White" CornerRadius="5" Padding="10" BorderBrush="#BDC3C7" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="📋 Список заявок" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                <DataGrid x:Name="RequestsGrid" AutoGenerateColumns="False" CanUserAddRows="False" 
                          Height="300" Margin="0,0,0,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Клиент" Binding="{Binding Client}" Width="150"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                        <DataGridTextColumn Header="Оборудование" Binding="{Binding Equipment}" Width="150"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                        <DataGridTemplateColumn Header="Действия" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="❌" Background="#E74C3C" Foreground="White" 
                                            Width="30" Height="25" Click="BtnDelete_Click" 
                                            Tag="{Binding Id}" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock x:Name="TxtTotal" Text="Всего: 0 заявок" FontWeight="Bold" Foreground="#7F8C8D"/>
            </StackPanel>
        </Border>

        <!-- Статистика -->
        <Border Grid.Row="3" Background="#34495E" CornerRadius="5" Padding="10" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtNewCount" Text="Новых: 0" Foreground="White" Margin="0,0,20,0"/>
                <TextBlock x:Name="TxtWorkCount" Text="В работе: 0" Foreground="White" Margin="0,0,20,0"/>
                <TextBlock x:Name="TxtDoneCount" Text="Выполнено: 0" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>